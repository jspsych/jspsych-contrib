{
  "name": "plugin-audio-response",
  "version": "0.0.1",
  "description": "A jsPsych plugin that plays an audio stimulus and records the participant's spoken response, with VAD-based auto-stop and optional Whisper transcription.",
  "type": "module",
  "main": "dist/index.cjs",
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "typings": "dist/index.d.ts",
  "unpkg": "dist/index.browser.min.js",
  "files": [
    "src",
    "dist"
  ],
  "source": "src/index.ts",
  "scripts": {
    "test": "jest",
    "test:watch": "npm test -- --watch",
    "tsc": "tsc",
    "build": "rollup --config",
    "build:watch": "npm run build -- --watch"
  },
  "repository": {
    "type": "git",
    "url": "",
    "directory": "./"
  },
  "keywords": [
    "jsPsych"
  ],
  "author": {
    "name": "",
    "url": ""
  },
  "license": "MIT",
  "bugs": {
    "url": "/issues"
  },
  "homepage": "/plugin-audio-response/README.md",
  "dependencies": {
    "@huggingface/transformers": "^3.8.1"
  },
  "peerDependencies": {
    "jspsych": ">=8.0.0"
  },
  "devDependencies": {
    "@jspsych/config": "^3.2.2",
    "@jspsych/test-utils": "^1.0.0",
    "@types/audioworklet": "^0.0.75",
    "jspsych": "^8.0.0"
  }
}
